# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://GROUP23:yourpassword@maas-sw-d281-u2108.nam.nsroot.net:37017/group23?tls=true&authMechanism=DEFAULT&tlsInsecure=true
MONGO_DB=group23

# ─── SharePoint ────────────────────────────────────────────────────────────────
# Sites to crawl (comma-separated)
SHAREPOINT_SITE_URLS=https://citi.sharepoint.com/sites/yoursite

# ── Auth Option A: Cookie auth (RECOMMENDED for citi.sharepoint.com) ──────────
# Step 1: Open your SharePoint site in Chrome/Edge while logged in
# Step 2: Press F12 → Application tab → Cookies → find citi.sharepoint.com
# Step 3: Copy the VALUE of FedAuth and rtFa cookies and paste below
SHAREPOINT_FED_AUTH=your-fedauth-cookie-value-here
SHAREPOINT_RT_FA=your-rtfa-cookie-value-here

# ── Auth Option B: Username/password (on-premise NTLM only) ───────────────────
# Only use this if cookie auth doesn't work
# SHAREPOINT_AUTH_TYPE=ntlm
# SHAREPOINT_USERNAME=DOMAIN\username
# SHAREPOINT_PASSWORD=your-windows-password

# ─── Confluence ────────────────────────────────────────────────────────────────
CONFLUENCE_URL=https://cedt-confluence.nam.nsroot.net/confluence
CONFLUENCE_API_TOKEN=your-confluence-pat-token
CONFLUENCE_SPACES=

# ─── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://cedt-icg-jira.nam.nsroot.net
JIRA_API_TOKEN=your-jira-pat-token
JIRA_PROJECTS=

# ─── App ───────────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60
MAX_RESULTS_PER_PAGE=20

# ─── GitHub Enterprise ─────────────────────────────────────────────────────────
# Your GHE hostname (without https://) e.g. github.citi.com
GITHUB_HOST=github.yourcompany.com

# Create PAT at: https://github.yourcompany.com/settings/tokens
# Needs: repo (read) scope
GITHUB_TOKEN=your-ghe-pat-token

# Option A: specific repos (comma-separated owner/repo)
GITHUB_REPOS=your-org/repo1,your-org/repo2

# Option B: crawl all repos in an org
# GITHUB_ORG=your-org

# Max commits per repo per sync (default 200)
GITHUB_MAX_COMMITS=200
